# Gemini API Configuration
GOOGLE_API_KEY=your_gemini_api_key_here

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here  # e.g., gcp-starter
PINECONE_INDEX_NAME=financial-documents

# App Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
CHUNK_SIZE=1000  # Characters per chunk
CHUNK_OVERLAP=100  # Character overlap between chunks
MAX_RETRIEVED_CHUNKS=5  # Number of chunks to retrieve for each query
MODEL_NAME=gemini-1.5-flash  # Gemini model for generation
EMBEDDING_MODEL=models/embedding-001  # Gemini embedding model

# Streamlit Configuration (optional)
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
